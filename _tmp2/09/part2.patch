new file mode 100644
--- /dev/null	(revision 863654982b4e2a93384ee37745aa8a5044560a34)
+++ b/k8s/app-config-map.yaml	(revision 863654982b4e2a93384ee37745aa8a5044560a34)
@@ -0,0 +1,29 @@
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: app-config
+  namespace: microservices
+data:
+  resources_db_url: "resources-db-service"
+  resources_db_port: "5432"
+  songs_db_url: "songs-db-service"
+
+  resources_init.sql: |
+    create table resources (
+        id serial not null,
+        blob bytea,
+        primary key (id)
+    );
+  songs_init.sql: |
+    create sequence songs_seq start with 1 increment by 50;
+    create table songs (
+        id integer not null,
+        resource_id integer not null unique,
+        album varchar(255),
+        artist varchar(255),
+        length varchar(255),
+        name varchar(255),
+        year varchar(255),
+        genre varchar(255),
+        primary key (id)
+    );
